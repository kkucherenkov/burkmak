# Hostname or LAN IP that browsers/e-readers will use to reach this machine.
# NOT localhost (unless everything runs on the same box you browse from).
BURKMAK_HOST=192.168.1.50

# Session-signing secret. Generate one: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me

# Image tag to run: a release version like 0.1.0, or latest.
IMAGE_TAG=latest

# Published host ports.
BACKEND_PORT=3000
WEB_PORT=3001
