// Prisma schema — Better Auth tables are generated by
// `pnpm --filter @app/backend auth:generate-schema` and merged here.
// Add domain models below the auth section.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ----- Better Auth -----

model User {
  id                   String                 @id
  name                 String
  email                String                 @unique
  emailVerified        Boolean
  image                String?
  createdAt            DateTime
  updatedAt            DateTime
  phoneNumber          String?                @unique
  phoneNumberVerified  Boolean?
  sessions             Session[]
  accounts             Account[]
  personalAccessTokens PersonalAccessToken[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// ----- Domain -----

model Job {
  id          String    @id @default(cuid())
  userId      String
  type        String
  itemId      String?
  status      String    @default("queued") // queued | running | done | failed
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  runAfter    DateTime  @default(now())
  error       String?
  payload     String? // JSON-encoded
  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?

  @@index([status, runAfter])
  @@map("job")
}

model Item {
  id            String      @id @default(cuid())
  userId        String
  url           String
  canonicalUrl  String?
  title         String?
  siteName      String?
  excerpt       String?
  leadImageUrl  String?
  faviconUrl    String?
  status        String      @default("pending") // pending | ready | failed
  readState     String      @default("unread")  // unread | read | archived
  favorite      Boolean     @default(false)
  savedAt       DateTime    @default(now())
  readAt        DateTime?
  updatedAt     DateTime    @updatedAt
  extractStatus String      @default("none") // none | extracting | ready | failed
  kind          String      @default("article") // article | bookmark
  tags          ItemTag[]
  shelves       ShelfItem[]
  article       Article?
  highlights    Highlight[]
  koboEntitlement  KoboEntitlement?
  koboReadingState KoboReadingState?

  @@index([userId, readState])
  @@index([userId, savedAt])
  @@index([userId, kind])
  @@map("item")
}

model Article {
  itemId         String   @id
  contentHtml    String
  contentText    String
  wordCount      Int
  readingTimeMin Int
  // Filename (<sha1>.<ext>) of the first cached content image — the OPDS
  // cover. Null when the article has no cached images.
  coverImageKey  String?
  extractedAt    DateTime @default(now())
  item           Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("article")
}

// One row per (item ever emitted to a Kobo device). Existence = "already
// synced" (Calibre-Web's KoboSyncedBooks design); the uuid is the stable
// entitlement/RevisionId the device knows the book by. itemId goes NULL when
// the item is deleted — the orphan row emits one IsRemoved delta, then is
// purged by the sync service.
model KoboEntitlement {
  uuid      String   @id @default(uuid())
  itemId    String?  @unique
  userId    String
  createdAt DateTime @default(now())
  item      Item?    @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@map("kobo_entitlement")
}

// Device-reported reading state, stored verbatim (JSON strings) so the device
// round-trips its own bookmark/statistics exactly. lastModified drives the
// ChangedReadingState delta in /v1/library/sync.
model KoboReadingState {
  itemId            String   @id
  userId            String
  statusInfo        String // JSON — {"Status": "Reading" | "Finished" | "ReadyToRead", ...}
  statistics        String? // JSON
  currentBookmark   String? // JSON
  priorityTimestamp DateTime @default(now())
  createdAt         DateTime @default(now())
  lastModified      DateTime @updatedAt
  item              Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("kobo_reading_state")
}

model Highlight {
  id        String   @id @default(cuid())
  itemId    String
  userId    String
  quote     String
  prefix    String   @default("")
  suffix    String   @default("")
  note      String?
  color     String   @default("yellow") // yellow | green | blue | pink
  createdAt DateTime @default(now())
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, userId])
  @@map("highlight")
}

model Tag {
  id     String    @id @default(cuid())
  userId String
  name   String
  slug   String
  items  ItemTag[]

  @@unique([userId, slug])
  @@map("tag")
}

model ItemTag {
  itemId String
  tagId  String
  item   Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
  @@map("item_tag")
}

model PersonalAccessToken {
  id         String    @id @default(cuid())
  userId     String
  name       String
  tokenHash  String    @unique
  prefix     String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Shelf {
  id           String      @id @default(uuid()) // doubles as Kobo Tag.Id (slice ③b)
  userId       String
  name         String
  createdAt    DateTime    @default(now())
  // Bumped on rename AND on membership change. @updatedAt only fires for writes
  // to this row, so membership changes touch it explicitly (see ShelfRepo).
  lastModified DateTime    @updatedAt
  items        ShelfItem[]

  @@unique([userId, name])
  @@map("shelf")
}

model ShelfItem {
  shelfId String
  itemId  String
  addedAt DateTime @default(now())
  shelf   Shelf    @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  item    Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([shelfId, itemId])
  // `@@id` leads with shelfId, so shelf -> items rides the PK but item -> shelves
  // does not. ItemTag needs no equivalent: its @@id leads with itemId.
  @@index([itemId])
  @@map("shelf_item")
}
