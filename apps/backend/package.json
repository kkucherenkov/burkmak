{
  "name": "@app/backend",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "App NestJS backend",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=text",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.build.json && tsc --noEmit -p tsconfig.test.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "node --experimental-strip-types prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && pnpm db:seed",
    "auth:generate-schema": "better-auth generate --output prisma/schema.prisma"
  },
  "dependencies": {
    "@app/api-client-ts": "workspace:*",
    "@app/specs": "workspace:*",
    "@mozilla/readability": "^0.6.0",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.1.28",
    "@nestjs/cqrs": "^11.0.0",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/throttler": "^6.3.0",
    "@prisma/adapter-better-sqlite3": "^7.9.0",
    "@prisma/client": "^7.7.0",
    "better-auth": "^1.6.11",
    "better-sqlite3": "^12.11.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dataloader": "^2.2.3",
    "express": "^5.2.1",
    "express-openapi-validator": "^5.4.0",
    "firebase-admin": "^14.2.0",
    "helmet": "^8.3.0",
    "jszip": "^3.10.1",
    "linkedom": "^0.18.13",
    "nanoid": "^6.0.0",
    "nestjs-i18n": "^10.8.5",
    "node-html-parser": "^9.0.0",
    "prisma": "^7.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.17.6"
  },
  "devDependencies": {
    "@app/eslint-config": "workspace:*",
    "@app/tsconfig": "workspace:*",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.0",
    "@swc/core": "^1.15.26",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/node": "^25.6.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "unplugin-swc": "^1.5.9",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0",
    "yaml": "^2.8.3"
  }
}
